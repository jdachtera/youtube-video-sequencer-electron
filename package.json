      "babel-preset-solid": "1.6.16",
      "@types/minimatch": "5.1.2",
      "tone": "14.7.77",
      "@emotion/css": "11.10.5",
      "solid-icons": "1.0.4",
      "prettier": "2.8.0",
      "caniuse-lite": "^1.0.30001799"
    }
  },
  "dependencies": {
    "@apollo/client": "^3.7.2",
    "@emotion/css": "^11.10.5",
    "@i2labs/dns": "^1.0.1",
    "@jdachtera/youtube-search-without-api-key": "^1.0.8",
    "@merged/solid-apollo": "^1.7.1",
    "electron-updater": "^6.8.9",
    "events": "^3.3.0",
    "file-saver": "^2.0.5",
    "graphql": "^16.6.0",
    "http-browserify": "^1.7.0",
    "https-browserify": "^1.0.0",
    "idb": "^7.1.1",
    "polished": "^4.1.4",
    "prettier": "^2.8.0",
    "querystring": "^0.2.1",
    "regenerator-runtime": "^0.13.11",
    "solid-dismiss": "^1.4.1",
    "solid-icons": "^1.0.4",
    "solid-js": "1.6.3",
    "solid-pianoroll": "^0.0.28",
    "solid-waveform": "^1.0.11",
    "stream-browserify": "^3.0.0",
    "timers-browserify": "^2.0.12",
    "tiny-typed-emitter": "^2.1.0",
    "tone": "^14.7.77",
    "ts-debounce": "^4.0.0",
    "util": "^0.12.5",
    "vite-plugin-solid": "^2.11.12",
    "vm-browserify": "^1.1.2",
    "youtubei.js": "^17.0.1"
  },
  "packageManager": "pnpm@9.15.9"
}
