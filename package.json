    "@i2labs/dns": "^1.0.1",
    "@jdachtera/youtube-search-without-api-key": "^1.0.8",
    "@merged/solid-apollo": "^1.7.1",
    "electron-updater": "5.3.0",
    "events": "^3.3.0",
    "file-saver": "^2.0.5",
    "graphql": "^16.6.0",
    "http-browserify": "^1.7.0",
    "https-browserify": "^1.0.0",
    "idb": "^7.1.0",
    "polished": "^4.1.4",
    "prettier": "^2.7.1",
    "querystring": "^0.2.1",
    "regenerator-runtime": "^0.13.10",
    "solid-dismiss": "^1.3.1",
    "solid-icons": "^1.0.2",
    "solid-js": "1.5.0",
    "stream-browserify": "^3.0.0",
    "timers-browserify": "^2.0.12",
    "tiny-typed-emitter": "^2.1.0",
    "tone": "^14.7.77",
    "ts-debounce": "^4.0.0",
    "util": "^0.12.5",
    "vite-plugin-solid": "^2.3.10",
    "vm-browserify": "^1.1.2",
    "yarn": "^1.22.19",
    "ytdl-core": "^4.11.2",
    "ytdl-core-browser": "^1.0.0"
  }
}
