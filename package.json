{
  "name": "youtube-video-sequencer-electron",
  "description": "Youtube video Sequencer",
  "private": true,
  "engines": {
    "node": ">=v16.13",
    "npm": ">=8.1"
  },
  "main": "packages/main/dist/index.cjs",
  "scripts": {
    "build": "npm run build:main && npm run build:preload && npm run build:renderer",
    "build:main": "cd ./packages/main && vite build",
    "build:preload": "cd ./packages/preload && vite build",
    "build:renderer": "cd ./packages/renderer && vite build",
    "compile": "cross-env MODE=production npm run build && electron-builder build --config .electron-builder.config.js --dir",
    "test": "npm run test:main && npm run test:preload && npm run test:renderer && npm run test:e2e",
    "test:e2e": "npm run build && vitest run",
    "test:main": "vitest run -r packages/main --passWithNoTests",
    "test:preload": "vitest run -r packages/preload --passWithNoTests",
    "test:renderer": "vitest run -r packages/renderer --passWithNoTests",
    "start": "node scripts/watch.js",
    "lint": "eslint . --ext js,ts,tsx",
    "typecheck:main": "tsc --noEmit -p packages/main/tsconfig.json",
    "typecheck:preload": "tsc --noEmit -p packages/preload/tsconfig.json",
    "typecheck:renderer": "tsc --noEmit -p packages/renderer/tsconfig.json",
    "typecheck": "npm run typecheck:main && npm run typecheck:preload && npm run typecheck:renderer",
    "prepare": "husky install",
    "graphql-codegen": "graphql-codegen --config codegen.yml"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "cross-env NODE_ENV=development eslint --cache"
    ],
    "*.json,.{eslintrc,prettierrc}": [
      "prettier --ignore-path .eslintignore --parser json --write"
    ],
    "*.{css,scss}": [
      "prettier --ignore-path .eslintignore --single-quote --write"
    ],
    "*.{html,md,yml}": [
      "prettier --ignore-path .eslintignore --single-quote --write"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jdachtera/youtube-video-sequencer-electron.git"
  },
  "author": {
    "name": "Youtube Video Sequencer",
    "email": "jascha.dachtera@gmail.com",
    "url": "https://github.com/jdachtera/youtube-video-sequencer-electron"
  },
  "contributors": [
    {
      "name": "Jascha Dachtera",
      "email": "jascha.dachtera@gmail.com",
      "url": "https://github.com/jdachtera"
    },
    {
      "name": "Christian Sandner",
      "email": "chris@pyracom.de",
      "url": "https://github.com/pyracom"
    }
  ],
  "license": "UNLICENSED",
  "bugs": {
    "url": "https://github.com/jdachtera/youtube-video-sequencer-electron/issues"
  },
  "keywords": [
    "electron",
    "boilerplate",
    "react",
    "typescript",
    "ts",
    "sass",
    "webpack",
    "hot",
    "reload"
  ],
  "homepage": "https://github.com/jdachtera/youtube-video-sequencer-electron#readme",
  "devDependencies": {
    "@babel/core": "^7.19.6",
    "@graphql-codegen/cli": "^2.13.7",
    "@graphql-codegen/introspection": "2.2.1",
    "@graphql-codegen/near-operation-file-preset": "^2.4.3",
    "@graphql-codegen/typed-document-node": "^2.3.5",
    "@graphql-codegen/typescript-document-nodes": "2.3.5",
    "@graphql-codegen/typescript-operations": "^2.5.5",
    "@graphql-typed-document-node/core": "^3.1.1",
    "@types/babel__core": "^7.1.18",
    "@types/file-saver": "^2.0.5",
    "@types/node": "^18.11.4",
    "@types/wicg-file-system-access": "^2020.9.5",
    "@typescript-eslint/eslint-plugin": "5.40.1",
    "@typescript-eslint/parser": "^5.40.1",
    "cross-env": "7.0.3",
    "csstype": "^3.1.1",
    "electron": "^21.0.0",
    "electron-builder": "23.6.0",
    "electron-devtools-installer": "3.2.0",
    "eslint": "8.26.0",
    "eslint-config-prettier": "^8.5.0",
    "eslint-plugin-import": "^2.25.4",
    "eslint-plugin-prettier": "^4.2.1",
    "eslint-plugin-promise": "^6.1.1",
    "eslint-plugin-solid": "0.7.2",
    "eslint-plugin-unused-imports": "^2.0.0",
    "happy-dom": "7.6.0",
    "husky": "^8.0.1",
    "lint-staged": "^13.0.3",
    "nano-staged": "0.8.0",
    "simple-git-hooks": "2.8.1",
    "ts-node": "^10.9.1",
    "typescript": "4.8.4",
    "vite": "3.1.8",
    "vitest": "0.24.3"
  },
  "dependencies": {
    "@apollo/client": "^3.7.0",
